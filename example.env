# OpenAlex 请求标识（建议填写）
OPENALEX_MAILTO=your-email@example.com
# 可选：OpenAlex 免费 API key，用于更稳定的高频检索
OPENALEX_API_KEY=

# 议题高质量生成（建议填写；不填则使用算法生成）
OPENAI_API_KEY=
TOPIC_LLM_MODEL=gpt-5.4-mini

# 候选人复核与重排模型（默认沿用 TOPIC_LLM_MODEL）
CANDIDATE_LLM_MODEL=gpt-5.4-mini

# 可选：第二学术数据源（不填则仅使用 OpenAlex）
SEMANTIC_SCHOLAR_API_KEY=

# 可选：是否启用链接可达性校验（true/false）
ENABLE_LINK_REACHABILITY_CHECK=false

# 可选：是否允许示例数据兜底（true/false）
# 强烈建议保持 false，避免演示数据进入正式结果
ENABLE_MOCK_FALLBACK=false

# 学者检索数据源策略：
# openalex = 仅使用 OpenAlex（默认推荐）
# hybrid = OpenAlex + Semantic Scholar（需配置 SEMANTIC_SCHOLAR_API_KEY）
SCHOLAR_SEARCH_PROVIDER=openalex
