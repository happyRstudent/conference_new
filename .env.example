# ============================================
# OpenAlex 学术检索
# ============================================
OPENALEX_MAILTO=your-email@example.com
OPENALEX_API_KEY=

# ============================================
# LLM API（议题生成 + 候选人推荐）
# 支持 OpenAI / DeepSeek / 任何兼容接口
# ============================================
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com

TOPIC_LLM_MODEL=deepseek-v4-flash
CANDIDATE_LLM_MODEL=deepseek-v4-flash

# ============================================
# 可选：链接可达性校验
# ============================================
ENABLE_LINK_REACHABILITY_CHECK=false

# ============================================
# 可选：是否允许示例数据兜底
# 强烈建议保持 false
# ============================================
ENABLE_MOCK_FALLBACK=false

# ============================================
# 可选：学者检索数据源策略
# openalex = 仅 OpenAlex（默认）
# hybrid = OpenAlex + Semantic Scholar
# ============================================
SCHOLAR_SEARCH_PROVIDER=openalex
